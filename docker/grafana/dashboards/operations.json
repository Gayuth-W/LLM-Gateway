{
  "uid": "gw-operations",
  "title": "LLM Gateway — Operations",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate by outcome (req/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (outcome) (rate(gateway_requests_total[1m]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error ratio",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(gateway_requests_total{outcome=\"error\"}[2m])) / clamp_min(sum(rate(gateway_requests_total[2m])), 1)",
          "legendFormat": "error ratio"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "End-to-end latency (p50/p95/p99, seconds)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum(rate(gateway_request_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum(rate(gateway_request_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p95" },
        { "refId": "C", "expr": "histogram_quantile(0.99, sum(rate(gateway_request_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p99" }
      ]
    }
  ]
}
